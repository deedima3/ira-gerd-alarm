<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CutesyAlarm" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/primary_pink</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/background</item>
    </style>
    
    <style name="Theme.CutesyAlarm.FullScreen" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/secondary_pink</item>
        <item name="android:statusBarColor">@color/secondary_pink</item>
        <item name="android:navigationBarColor">@color/lavender</item>
    </style>
</resources>